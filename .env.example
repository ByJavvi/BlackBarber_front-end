# Copia este archivo como ".env" y ajusta la URL de tu backend.
# La capa src/api/client.js usa esta variable como base de todas las peticiones.
REACT_APP_API_URL=http://localhost:5000

# Mientras esté en "true" la app usa datos simulados (src/mocks) y NO llama al backend.
# Cambia a "false" cuando el backend esté disponible para consumir los endpoints reales.
REACT_APP_USE_MOCKS=true
